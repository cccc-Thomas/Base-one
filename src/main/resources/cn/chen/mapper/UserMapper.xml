<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="cn.chen.mapper.UserMapper">

    <!-- 查询单个用户 -->
    <select id="getNameById" resultType="java.lang.String">
        SELECT username
        FROM user
        WHERE id = #{id}
    </select>

</mapper>